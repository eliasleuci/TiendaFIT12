# Copiá este archivo a .env y completá con los datos de tu proyecto de Supabase
# (Project Settings > API en supabase.com)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# Numero de WhatsApp donde llegan los pedidos.
# Formato: codigo de pais + numero, sin espacios ni "+"
# Ejemplo Cordoba, Argentina: 5493511234567
VITE_WHATSAPP_NUMBER=5493511234567
